@page
@model DevHelp.Areas.Identity.Pages.Account.ConfirmEmailModel
@{
    ViewData["Title"] = "Confirmação de e-mail";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-7 col-md-9">
        <section class="card clean-card shadow-modern border-0">
            <div class="card-body p-4 p-lg-5">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi @(Model.IsSuccess ? "bi-patch-check-fill text-success" : "bi-exclamation-triangle-fill text-warning") fs-4"></i>
                    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
                </div>

                <p class="text-secondary mb-3">@Model.StatusMessage</p>

                @if (Model.IsSuccess)
                {
                    <div class="info-chip p-3 rounded-3 mb-4">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi bi-clock-history text-primary"></i>
                            <strong>Redirecionamento automático</strong>
                        </div>
                        <small class="text-secondary d-block">Você será redirecionado para o login em 5 segundos.</small>
                    </div>
                }
                else
                {
                    <div class="info-chip p-3 rounded-3 mb-4">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi bi-info-circle-fill text-primary"></i>
                            <strong>Ação recomendada</strong>
                        </div>
                        <small class="text-secondary d-block">Solicite um novo link de confirmação e tente novamente.</small>
                    </div>
                }

                <div class="d-grid gap-2 d-sm-flex">
                    <a asp-page="./Login" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Ir para login
                    </a>
                    <a asp-page="./ResendEmailConfirmation" class="btn btn-outline-secondary btn-lg">
                        <i class="bi bi-arrow-repeat me-1"></i>Reenviar confirmação
                    </a>
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    @if (Model.IsSuccess)
    {
        <script>
            setTimeout(function () {
                window.location.href = '@Url.Page("./Login")';
            }, 5000);
        </script>
    }
}
