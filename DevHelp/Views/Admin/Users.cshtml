@model DevHelp.Models.Admin.UserManagementPageViewModel
@{
    ViewData["Title"] = "Administração de Usuários";
}

<div class="row mt-4">
    <div class="col-12">
        <div class="card clean-card border-0 shadow-modern">
            <div class="card-body p-4">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                    <div>
                        <h1 class="h3 mb-1"><i class="bi bi-shield-lock-fill text-primary me-2"></i>Administração de Usuários</h1>
                        <p class="text-secondary mb-0">Gerencie papéis, bloqueio de acesso e redefinição de senha.</p>
                    </div>
                </div>

                @if (TempData["AdminSuccess"] is string successMessage)
                {
                    <div class="alert alert-success" role="alert">@successMessage</div>
                }

                @if (TempData["AdminError"] is string errorMessage)
                {
                    <div class="alert alert-danger" role="alert">@errorMessage</div>
                }

                <form method="get" asp-action="Users" class="row g-2 align-items-end mb-3" id="users-filter-form">
                    <div class="col-lg-5 col-md-6">
                        <label for="searchTerm" class="form-label">Buscar por nome ou e-mail</label>
                        <input id="searchTerm" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Digite nome ou e-mail" />
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <label for="roleFilter" class="form-label">Filtrar por papel</label>
                        <select id="roleFilter" name="roleFilter" class="form-select">
                            @if (string.IsNullOrWhiteSpace(Model.RoleFilter))
                            {
                                <option value="" selected>Todos</option>
                            }
                            else
                            {
                                <option value="">Todos</option>
                            }
                            <option value="Aluno" selected="@(Model.RoleFilter == "Aluno")">Aluno</option>
                            <option value="Professor" selected="@(Model.RoleFilter == "Professor")">Professor</option>
                            <option value="Admin" selected="@(Model.RoleFilter == "Admin")">Admin</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4">
                        <label for="pageSize" class="form-label">Registros</label>
                        <select id="pageSize" name="pageSize" class="form-select">
                            <option value="10" selected="@(Model.PageSize == 10)">10</option>
                            <option value="20" selected="@(Model.PageSize == 20)">20</option>
                            <option value="50" selected="@(Model.PageSize == 50)">50</option>
                        </select>
                    </div>
                    <input type="hidden" name="page" value="1" />
                    <div class="col-lg-2 col-md-8 d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search me-1"></i>Buscar
                        </button>
                        <a asp-action="Users" class="btn btn-outline-secondary w-100">Limpar</a>
                    </div>
                </form>

                <div class="small text-secondary mb-2">
                    Exibindo @Model.Users.Count de @Model.TotalRecords usuário(s).
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Usuário</th>
                                <th>Status</th>
                                <th>Papel</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@user.DisplayName</div>
                                    <div class="text-secondary small">@user.Email</div>
                                </td>
                                <td>
                                    @if (user.IsLocked)
                                    {
                                        <span class="badge text-bg-danger">Bloqueado</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">Ativo</span>
                                    }

                                    @if (user.EmailConfirmed)
                                    {
                                        <span class="badge text-bg-primary ms-1">E-mail confirmado</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary ms-1">E-mail pendente</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge text-bg-light border">@user.Role</span>
                                </td>
                                <td class="text-end">
                                    @if (user.Role == "Admin")
                                    {
                                        <span class="text-secondary small">Conta administrativa protegida</span>
                                    }
                                    else
                                    {
                                        <div class="d-inline-flex flex-wrap justify-content-end gap-2">
                                            <form asp-action="ChangeRole" method="post" class="d-inline-flex gap-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.UserId" />
                                                <select name="targetRole" class="form-select form-select-sm" style="width: 130px;">
                                                    @if (user.Role == "Professor")
                                                    {
                                                        <option value="Aluno">Aluno</option>
                                                        <option value="Professor" selected>Professor</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="Aluno" selected>Aluno</option>
                                                        <option value="Professor">Professor</option>
                                                    }
                                                </select>
                                                <button type="submit" class="btn btn-outline-primary btn-sm">
                                                    <i class="bi bi-arrow-repeat me-1"></i>Trocar papel
                                                </button>
                                            </form>

                                            @if (user.IsLocked)
                                            {
                                                <form asp-action="UnblockUser" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.UserId" />
                                                    <button type="submit" class="btn btn-outline-success btn-sm">
                                                        <i class="bi bi-unlock-fill me-1"></i>Desbloquear
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="BlockUser" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.UserId" />
                                                    <button type="submit" class="btn btn-outline-warning btn-sm">
                                                        <i class="bi bi-lock-fill me-1"></i>Bloquear
                                                    </button>
                                                </form>
                                            }

                                            <form asp-action="SendPasswordReset" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.UserId" />
                                                <button type="submit" class="btn btn-outline-info btn-sm">
                                                    <i class="bi bi-envelope-arrow-up me-1"></i>Resetar senha
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Paginação de usuários" class="mt-3">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : null)">
                                <a class="page-link"
                                   asp-action="Users"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-roleFilter="@Model.RoleFilter"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-page="@(Model.CurrentPage - 1)">Anterior</a>
                            </li>

                            @for (var i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : null)">
                                    <a class="page-link"
                                       asp-action="Users"
                                       asp-route-searchTerm="@Model.SearchTerm"
                                       asp-route-roleFilter="@Model.RoleFilter"
                                       asp-route-pageSize="@Model.PageSize"
                                       asp-route-page="@i">@i</a>
                                </li>
                            }

                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : null)">
                                <a class="page-link"
                                   asp-action="Users"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-roleFilter="@Model.RoleFilter"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-page="@(Model.CurrentPage + 1)">Próxima</a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const searchInput = document.getElementById('searchTerm');
            const filterForm = document.getElementById('users-filter-form');
            if (!searchInput || !filterForm) {
                return;
            }

            searchInput.addEventListener('input', function () {
                if (searchInput.value.trim() === '') {
                    filterForm.submit();
                }
            });
        })();
    </script>
}
