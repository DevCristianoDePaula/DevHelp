@model DevHelp.Models.Admin.CategoryFormViewModel
@{
    ViewData["Title"] = "Editar Categoria";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-7 col-md-9">
        <section class="card clean-card shadow-modern border-0">
            <div class="card-body p-4 p-lg-5">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-pencil-square text-primary fs-4"></i>
                    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
                </div>
                <p class="text-secondary mb-4">Atualize os dados da categoria selecionada.</p>

                <form method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Name" class="form-control" placeholder="Nome" />
                        <label asp-for="Name"></label>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <textarea asp-for="Description" class="form-control" placeholder="Descrição" style="height: 120px"></textarea>
                        <label asp-for="Description"></label>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check2-circle me-1"></i>Salvar alterações
                        </button>
                        <a asp-action="Categories" class="btn btn-outline-secondary btn-lg">Cancelar</a>
                    </div>
                </form>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
