@model DevHelp.Models.Admin.CategoryManagementPageViewModel
@{
    ViewData["Title"] = "Categorias";
}

<div class="row mt-4">
    <div class="col-12">
        <div class="card clean-card border-0 shadow-modern">
            <div class="card-body p-4">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                    <div>
                        <h1 class="h3 mb-1"><i class="bi bi-tags-fill text-primary me-2"></i>Categorias</h1>
                        <p class="text-secondary mb-0">CRUD administrativo de categorias para classificação de chamados.</p>
                    </div>
                    <a asp-action="CreateCategory" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i>Nova categoria
                    </a>
                </div>

                @if (TempData["AdminSuccess"] is string successMessage)
                {
                    <div class="alert alert-success" role="alert">@successMessage</div>
                }

                @if (TempData["AdminError"] is string errorMessage)
                {
                    <div class="alert alert-danger" role="alert">@errorMessage</div>
                }

                <form method="get" asp-action="Categories" class="row g-2 align-items-end mb-3" id="categories-filter-form">
                    <div class="col-lg-8 col-md-8">
                        <label for="searchTerm" class="form-label">Buscar por nome ou descrição</label>
                        <input id="searchTerm" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Digite nome ou descrição" />
                    </div>
                    <div class="col-lg-2 col-md-4">
                        <label for="pageSize" class="form-label">Registros</label>
                        <select id="pageSize" name="pageSize" class="form-select">
                            <option value="10" selected="@(Model.PageSize == 10)">10</option>
                            <option value="20" selected="@(Model.PageSize == 20)">20</option>
                            <option value="50" selected="@(Model.PageSize == 50)">50</option>
                        </select>
                    </div>
                    <input type="hidden" name="page" value="1" />
                    <div class="col-lg-2 col-md-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search me-1"></i>Buscar
                        </button>
                        <a asp-action="Categories" class="btn btn-outline-secondary w-100">Limpar</a>
                    </div>
                </form>

                <div class="small text-secondary mb-2">
                    Exibindo @Model.Categories.Count de @Model.TotalRecords categoria(s).
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Descrição</th>
                                <th>Criada em</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.Categories.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-secondary py-4">Nenhuma categoria encontrada.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var category in Model.Categories)
                            {
                                <tr>
                                    <td class="fw-semibold">@category.Name</td>
                                    <td class="text-secondary">@(string.IsNullOrWhiteSpace(category.Description) ? "-" : category.Description)</td>
                                    <td>@category.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <div class="d-inline-flex gap-2">
                                            <a asp-action="EditCategory" asp-route-id="@category.Id" class="btn btn-outline-primary btn-sm">
                                                <i class="bi bi-pencil-square me-1"></i>Editar
                                            </a>
                                            <form asp-action="DeleteCategory" method="post" class="d-inline" onsubmit="return confirm('Deseja excluir esta categoria?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@category.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                                    <i class="bi bi-trash me-1"></i>Excluir
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Paginação de categorias" class="mt-3">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : null)">
                                <a class="page-link"
                                   asp-action="Categories"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-page="@(Model.CurrentPage - 1)">Anterior</a>
                            </li>

                            @for (var i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : null)">
                                    <a class="page-link"
                                       asp-action="Categories"
                                       asp-route-searchTerm="@Model.SearchTerm"
                                       asp-route-pageSize="@Model.PageSize"
                                       asp-route-page="@i">@i</a>
                                </li>
                            }

                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : null)">
                                <a class="page-link"
                                   asp-action="Categories"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-page="@(Model.CurrentPage + 1)">Próxima</a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const searchInput = document.getElementById('searchTerm');
            const filterForm = document.getElementById('categories-filter-form');
            if (!searchInput || !filterForm) {
                return;
            }

            searchInput.addEventListener('input', function () {
                if (searchInput.value.trim() === '') {
                    filterForm.submit();
                }
            });
        })();
    </script>
}
