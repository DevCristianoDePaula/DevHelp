@model DevHelp.Models.Tickets.TicketAttendanceHistoryPageViewModel
@{
    ViewData["Title"] = "Histórico de Atendimentos";

    static string StatusBadgeClass(DevHelp.Models.Tickets.TicketStatus status)
    {
        return status switch
        {
            DevHelp.Models.Tickets.TicketStatus.Resolved => "text-bg-success",
            DevHelp.Models.Tickets.TicketStatus.Closed => "text-bg-secondary",
            DevHelp.Models.Tickets.TicketStatus.Cancelled => "text-bg-dark",
            DevHelp.Models.Tickets.TicketStatus.InProgress => "text-bg-warning",
            _ => "text-bg-primary"
        };
    }

    static string StatusText(DevHelp.Models.Tickets.TicketStatus status)
    {
        return status switch
        {
            DevHelp.Models.Tickets.TicketStatus.Resolved => "Resolvido",
            DevHelp.Models.Tickets.TicketStatus.Closed => "Fechado",
            DevHelp.Models.Tickets.TicketStatus.Cancelled => "Cancelado",
            DevHelp.Models.Tickets.TicketStatus.InProgress => "Em atendimento",
            _ => "Aberto"
        };
    }

    static string PriorityBadgeClass(DevHelp.Models.Tickets.TicketPriority priority)
    {
        return priority switch
        {
            DevHelp.Models.Tickets.TicketPriority.Urgent => "text-bg-danger",
            DevHelp.Models.Tickets.TicketPriority.High => "text-bg-warning",
            DevHelp.Models.Tickets.TicketPriority.Medium => "text-bg-info",
            _ => "text-bg-secondary"
        };
    }

    static string PriorityText(DevHelp.Models.Tickets.TicketPriority priority)
    {
        return priority switch
        {
            DevHelp.Models.Tickets.TicketPriority.Urgent => "Urgente",
            DevHelp.Models.Tickets.TicketPriority.High => "Alta",
            DevHelp.Models.Tickets.TicketPriority.Medium => "Média",
            _ => "Baixa"
        };
    }
}

<div class="row mt-4">
    <div class="col-12">
        <div class="card clean-card border-0 shadow-modern">
            <div class="card-body p-4">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                    <div>
                        <h1 class="h3 mb-1"><i class="bi bi-clock-history text-primary me-2"></i>@ViewData["Title"]</h1>
                        <p class="text-secondary mb-0">Listagem geral de chamados finalizados com filtros e paginação.</p>
                    </div>
                </div>

                <form method="get" asp-action="History" class="row g-2 align-items-end mb-3" id="history-filter-form">
                    <div class="col-lg-6 col-md-12">
                        <label for="searchTerm" class="form-label">Buscar por aluno, e-mail ou docente</label>
                        <input id="searchTerm" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Digite aluno, e-mail, docente ou ticket" />
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <label for="categoryId" class="form-label">Categoria</label>
                        <select id="categoryId" name="categoryId" class="form-select" asp-items="Model.CategoryOptions"></select>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <label for="priorityFilter" class="form-label">Prioridade</label>
                        <select id="priorityFilter" name="priorityFilter" class="form-select" asp-items="Model.PriorityOptions"></select>
                    </div>

                    <div class="w-100"></div>

                    <div class="col-lg-3 col-md-6">
                        <label for="dateFrom" class="form-label">Finalizado em (de)</label>
                        <input id="dateFrom" name="dateFrom" type="date" class="form-control" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <label for="dateTo" class="form-label">Finalizado em (até)</label>
                        <input id="dateTo" name="dateTo" type="date" class="form-control" value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="col-lg-2 col-md-6">
                        <label for="pageSize" class="form-label">Registros</label>
                        <select id="pageSize" name="pageSize" class="form-select">
                            <option value="10" selected="@(Model.PageSize == 10)">10</option>
                            <option value="20" selected="@(Model.PageSize == 20)">20</option>
                            <option value="50" selected="@(Model.PageSize == 50)">50</option>
                        </select>
                    </div>
                    <input type="hidden" name="page" value="1" />
                    <div class="col-lg-4 col-md-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search me-1"></i>Buscar
                        </button>
                        <a asp-action="History" class="btn btn-outline-secondary w-100">Limpar</a>
                    </div>
                </form>

                <form method="post" asp-action="RequestHistoryPdf" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                    <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                    <input type="hidden" name="priorityFilter" value="@Model.PriorityFilter" />
                    <input type="hidden" name="dateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="dateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-file-earmark-pdf me-1"></i>Exportar PDF (processamento em segundo plano)
                    </button>
                </form>

                <div class="small text-secondary mb-2">
                    Exibindo @Model.Items.Count de @Model.TotalRecords atendimento(s).
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Ticket</th>
                                <th>Aluno</th>
                                <th>E-mail aluno</th>
                                <th>Docente</th>
                                <th>Categoria</th>
                                <th>Status</th>
                                <th>Prioridade</th>
                                <th>Fim</th>
                                <th>Tempo</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.Items.Count == 0)
                        {
                            <tr>
                                <td colspan="10" class="text-center text-secondary py-4">Sem atendimentos encontrados para os filtros informados.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.TicketNumber</td>
                                    <td>@item.StudentName</td>
                                    <td class="small text-secondary">@item.StudentEmail</td>
                                    <td>
                                        <div>@item.ProfessorName</div>
                                        <div class="small text-secondary">@item.ProfessorEmail</div>
                                    </td>
                                    <td>@item.CategoryName</td>
                                    <td><span class="badge @StatusBadgeClass(item.Status)">@StatusText(item.Status)</span></td>
                                    <td><span class="badge @PriorityBadgeClass(item.Priority)">@PriorityText(item.Priority)</span></td>
                                    <td>@item.ServiceFinishedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.TotalServiceMinutes min</td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-eye me-1"></i>Detalhes
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Paginação do histórico" class="mt-3">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : null)">
                                <a class="page-link"
                                   asp-action="History"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-categoryId="@Model.CategoryId"
                                   asp-route-priorityFilter="@Model.PriorityFilter"
                                   asp-route-dateFrom="@(Model.DateFrom?.ToString("yyyy-MM-dd"))"
                                   asp-route-dateTo="@(Model.DateTo?.ToString("yyyy-MM-dd"))"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-page="@(Model.CurrentPage - 1)">Anterior</a>
                            </li>

                            @for (var i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : null)">
                                    <a class="page-link"
                                       asp-action="History"
                                       asp-route-searchTerm="@Model.SearchTerm"
                                       asp-route-categoryId="@Model.CategoryId"
                                       asp-route-priorityFilter="@Model.PriorityFilter"
                                       asp-route-dateFrom="@(Model.DateFrom?.ToString("yyyy-MM-dd"))"
                                       asp-route-dateTo="@(Model.DateTo?.ToString("yyyy-MM-dd"))"
                                       asp-route-pageSize="@Model.PageSize"
                                       asp-route-page="@i">@i</a>
                                </li>
                            }

                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : null)">
                                <a class="page-link"
                                   asp-action="History"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-categoryId="@Model.CategoryId"
                                   asp-route-priorityFilter="@Model.PriorityFilter"
                                   asp-route-dateFrom="@(Model.DateFrom?.ToString("yyyy-MM-dd"))"
                                   asp-route-dateTo="@(Model.DateTo?.ToString("yyyy-MM-dd"))"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-page="@(Model.CurrentPage + 1)">Próxima</a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1090;">
    <div id="historyExportToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <i class="bi bi-file-earmark-pdf text-primary me-2"></i>
            <strong class="me-auto">Relatório PDF</strong>
            <small>agora</small>
            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Fechar"></button>
        </div>
        <div class="toast-body" id="historyExportToastBody">
            Processando exportação...
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const searchInput = document.getElementById('searchTerm');
            const filterForm = document.getElementById('history-filter-form');
            if (!searchInput || !filterForm) {
                return;
            }

            searchInput.addEventListener('input', function () {
                if (searchInput.value.trim() === '') {
                    filterForm.submit();
                }
            });

            const jobId = @(Model.ExportJobId.HasValue ? Model.ExportJobId.Value : 0);
            if (!jobId) {
                return;
            }

            const toastElement = document.getElementById('historyExportToast');
            const toastBody = document.getElementById('historyExportToastBody');
            if (!toastElement || !toastBody) {
                return;
            }

            const toast = new bootstrap.Toast(toastElement, { delay: 10000 });
            let pollingHandle = null;

            function showToastMessage(html) {
                toastBody.innerHTML = html;
                toast.show();
            }

            async function pollExportStatus() {
                try {
                    const response = await fetch(`/Tickets/HistoryExportStatus?jobId=${jobId}`, { cache: 'no-store' });
                    if (!response.ok) {
                        return;
                    }

                    const data = await response.json();
                    if (!data || !data.status) {
                        return;
                    }

                    if (data.status === 'Completed') {
                        clearInterval(pollingHandle);
                        showToastMessage(`Relatório pronto. <a href="${data.downloadUrl}" target="_blank" rel="noopener noreferrer">Clique aqui para abrir</a>.`);
                        return;
                    }

                    if (data.status === 'Failed') {
                        clearInterval(pollingHandle);
                        const message = data.errorMessage || 'Falha ao gerar relatório.';
                        showToastMessage(`Não foi possível gerar o PDF: ${message}`);
                    }
                } catch {
                }
            }

            showToastMessage('Exportação em processamento. Você será avisado quando finalizar.');
            pollingHandle = setInterval(pollExportStatus, 3000);
            pollExportStatus();
        })();
    </script>
}
