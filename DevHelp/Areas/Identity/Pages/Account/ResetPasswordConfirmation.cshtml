@page
@model DevHelp.Areas.Identity.Pages.Account.ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Senha redefinida";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-7 col-md-9">
        <section class="card clean-card shadow-modern border-0">
            <div class="card-body p-4 p-lg-5 text-center">
                <div class="d-flex align-items-center justify-content-center gap-2 mb-3">
                    <i class="bi bi-patch-check-fill text-success fs-4"></i>
                    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
                </div>

                <p class="text-secondary mb-3">Sua senha foi redefinida com sucesso. Você já pode entrar no sistema com a nova senha.</p>

                <div class="info-chip p-3 rounded-3 mb-4 text-start">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <i class="bi bi-clock-history text-primary"></i>
                        <strong>Redirecionamento automático</strong>
                    </div>
                    <small class="text-secondary d-block">Você será redirecionado para o login em 5 segundos.</small>
                </div>

                <div class="d-grid gap-2 d-sm-flex justify-content-center">
                    <a asp-page="./Login" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Ir para login
                    </a>
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(function () {
            window.location.href = '@Url.Page("./Login")';
        }, 5000);
    </script>
}
