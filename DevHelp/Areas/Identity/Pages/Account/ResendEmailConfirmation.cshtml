@page
@model DevHelp.Areas.Identity.Pages.Account.ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Reenviar confirmação";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-6 col-md-8">
        <section class="card clean-card shadow-modern border-0">
            <div class="card-body p-4 p-lg-5">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-envelope-arrow-up-fill text-primary fs-4"></i>
                    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
                </div>
                <p class="text-secondary mb-4">Informe seu e-mail para receber um novo link de confirmação.</p>

                @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                {
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle-fill me-1"></i>@Model.StatusMessage
                    </div>
                }

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="nome@dominio.com" />
                        <label asp-for="Input.Email"></label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2 d-sm-flex">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-send-check me-1"></i>Reenviar e-mail
                        </button>
                        <a asp-page="./Login" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Ir para login
                        </a>
                    </div>
                </form>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
