@page
@model DevHelp.Pages.Profile.CompleteModel
@{
    ViewData["Title"] = "Meu Perfil";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-7 col-md-9">
        <section class="card clean-card shadow-modern border-0">
            <div class="card-body p-4 p-lg-5">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-person-vcard-fill text-primary fs-4"></i>
                    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
                </div>
                <p class="text-secondary">Complete ou atualize seus dados e, se desejar, altere sua senha na mesma tela.</p>

                @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                {
                    <div class="alert alert-success" role="alert">
                        <i class="bi bi-check-circle-fill me-1"></i>@Model.StatusMessage
                    </div>
                }

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input value="@Model.Email" class="form-control" placeholder="E-mail" readonly />
                        <label>E-mail de cadastro (somente leitura)</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.FullName" class="form-control" placeholder="Nome completo" />
                        <label asp-for="Input.FullName"></label>
                        <span asp-validation-for="Input.FullName" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.ClassGroup" class="form-control" placeholder="Turma" />
                        <label asp-for="Input.ClassGroup"></label>
                        <span asp-validation-for="Input.ClassGroup" class="text-danger"></span>
                    </div>

                    <div class="info-chip p-3 rounded-3 mb-3">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-shield-lock-fill text-primary"></i>
                            <strong>Alterar senha</strong>
                        </div>
                        <small class="text-secondary d-block mb-2">Preencha os campos abaixo somente se quiser trocar sua senha.</small>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.CurrentPassword" class="form-control" placeholder="Senha atual" autocomplete="new-password" />
                            <label asp-for="Input.CurrentPassword"></label>
                            <span asp-validation-for="Input.CurrentPassword" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.NewPassword" class="form-control" placeholder="Nova senha" autocomplete="new-password" />
                            <label asp-for="Input.NewPassword"></label>
                            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                        </div>

                        <div class="form-floating">
                            <input asp-for="Input.ConfirmNewPassword" class="form-control" placeholder="Confirmar nova senha" autocomplete="new-password" />
                            <label asp-for="Input.ConfirmNewPassword"></label>
                            <span asp-validation-for="Input.ConfirmNewPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check2-circle me-1"></i>Salvar perfil
                    </button>
                </form>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
