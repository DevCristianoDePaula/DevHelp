@page
@model DevHelp.Areas.Identity.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Acesso negado";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-7 col-md-9">
        <section class="card clean-card shadow-modern border-0">
            <div class="card-body p-4 p-lg-5">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-shield-x text-danger fs-4"></i>
                    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
                </div>

                <p class="text-secondary mb-3">
                    Você não possui permissão para acessar este recurso no momento.
                </p>

                <div class="info-chip p-3 rounded-3 mb-4">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <i class="bi bi-info-circle-fill text-primary"></i>
                        <strong>Como continuar</strong>
                    </div>
                    <small class="text-secondary d-block">Volte para a página inicial ou entre em contato com a administração do sistema.</small>
                </div>

                <div class="d-grid gap-2 d-sm-flex">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                        <i class="bi bi-house-door me-1"></i>Ir para Home
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Ir para Login
                    </a>
                </div>
            </div>
        </section>
    </div>
</div>
